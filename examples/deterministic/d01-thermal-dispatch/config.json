{
  "$schema": "https://raw.githubusercontent.com/cobre-rs/cobre/refs/heads/main/book/src/schemas/config.schema.json",
  "training": {
    "forward_passes": 1,
    "stopping_rules": [
      {
        "type": "iteration_limit",
        "limit": 64
      },
      {
        "type": "bound_stalling",
        "iterations": 2,
        "tolerance": 1e-8
      }
    ]
  },
  "simulation": {
    "enabled": false,
    "num_scenarios": 1
  },
  "modeling": {
    "inflow_non_negativity": {
      "method": "none"
    }
  }
}
