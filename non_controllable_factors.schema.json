{
  "$defs": {
    "RawBlockFactor": {
      "description": "Intermediate type for a single block factor.",
      "properties": {
        "block_id": {
          "description": "Block identifier.",
          "format": "int32",
          "type": "integer"
        },
        "factor": {
          "description": "Scaling factor. Must be strictly positive (> 0.0) and finite.",
          "format": "double",
          "type": "number"
        }
      },
      "required": [
        "block_id",
        "factor"
      ],
      "type": "object"
    },
    "RawNcsFactorEntry": {
      "description": "Intermediate type for a single NCS factor entry (one NCS-stage pair).",
      "properties": {
        "block_factors": {
          "description": "Per-block scaling factors for this NCS-stage pair.",
          "items": {
            "$ref": "#/$defs/RawBlockFactor"
          },
          "type": "array"
        },
        "ncs_id": {
          "description": "NCS entity identifier.",
          "format": "int32",
          "type": "integer"
        },
        "stage_id": {
          "description": "Stage identifier.",
          "format": "int32",
          "type": "integer"
        }
      },
      "required": [
        "ncs_id",
        "stage_id",
        "block_factors"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Top-level intermediate type for `non_controllable_factors.json`.",
  "properties": {
    "$schema": {
      "description": "`$schema` field — informational, not validated.",
      "type": [
        "string",
        "null"
      ]
    },
    "non_controllable_factors": {
      "description": "Array of NCS factor entries.",
      "items": {
        "$ref": "#/$defs/RawNcsFactorEntry"
      },
      "type": "array"
    }
  },
  "required": [
    "non_controllable_factors"
  ],
  "title": "RawNcsFactorsFile",
  "type": "object"
}